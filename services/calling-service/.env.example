# Calling Service Configuration
CALLING_SERVICE_PORT=3051
NODE_ENV=development

# Database
MONGODB_URI=mongodb://root:nexora_dev_password@localhost:27017/nexora_calling?authSource=admin
MONGODB_DATABASE=nexora_calling

# JWT
JWT_SECRET=nexora_dev_jwt_secret_change_in_production_with_strong_random_key

# Redis (for call session tracking)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=nexora_dev_password
REDIS_URL=redis://:nexora_dev_password@localhost:6379/0

# WebRTC Configuration
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=

# Logging
LOG_LEVEL=debug
