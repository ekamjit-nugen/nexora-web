# ============================================================================
# NEXORA ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update with your values
# DO NOT commit .env to version control
# ============================================================================

# ============================================================================
# ENVIRONMENT & LOGGING
# ============================================================================
NODE_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=json

# ============================================================================
# MODULAR MONOLITH (current architecture)
# ============================================================================
# All 17 application modules live in services/api and run as a single
# container. Frontend points at this URL (see NEXT_PUBLIC_API_URL below).
API_PORT=3015

# Frontend public env — these get BAKED into the Next.js bundle at build
# time, so changing them requires a frontend rebuild
# (`docker compose build --no-cache frontend`).
# Override these when accessing from a different machine on your LAN
# (e.g. NEXT_PUBLIC_API_URL=http://192.168.x.y:3015 for mobile testing).
NEXT_PUBLIC_API_URL=http://localhost:3015
NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:3015
NEXT_PUBLIC_CALL_SOCKET_URL=http://localhost:3015

# ============================================================================
# LEGACY 18-MICROSERVICES PORTS (kept for reference / rollback only)
# ============================================================================
# These are only used when checking out the `microservices` branch or the
# `v18-microservices-final` tag. The current main branch's
# docker-compose.simple.yml does NOT reference them.
API_GATEWAY_PORT=3005
API_GATEWAY_HOST=0.0.0.0
AUTH_SERVICE_PORT=3001
REALTIME_SERVICE_PORT=3002
FILE_SERVICE_PORT=3004

HR_SERVICE_PORT=3010
ATTENDANCE_SERVICE_PORT=3011
PAYROLL_SERVICE_PORT=3012

PROJECT_SERVICE_PORT=3020
TASK_SERVICE_PORT=3021
BOARD_SERVICE_PORT=3022

CRM_SERVICE_PORT=3030
INVOICE_SERVICE_PORT=3031
EXPENSE_SERVICE_PORT=3032

DOCUMENT_SERVICE_PORT=3040
ASSET_SERVICE_PORT=3041

RECRUITMENT_SERVICE_PORT=3050
NOTIFICATION_SERVICE_PORT=3060
ANALYTICS_SERVICE_PORT=3070
AI_SERVICE_PORT=3080
INTEGRATION_SERVICE_PORT=3090

# ============================================================================
# DATABASE
# ============================================================================
MONGODB_URI=mongodb://root:nexora_dev_password@localhost:27017/nexora?authSource=admin
MONGODB_DATABASE=nexora
MONGODB_USER=nexora_app
MONGODB_PASSWORD=change_me_in_production

# ============================================================================
# REDIS (Cache & Sessions)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=nexora_dev_password
REDIS_DATABASE=0
REDIS_URL=redis://:nexora_dev_password@localhost:6379/0

# ============================================================================
# ELASTICSEARCH (Search & Logs)
# ============================================================================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ============================================================================
# SERVICE MESH & DISCOVERY
# ============================================================================
CONSUL_HOST=localhost
CONSUL_PORT=8500
CONSUL_DATACENTER=dc1
CONSUL_TOKEN=

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================
JWT_SECRET=nexora_dev_jwt_secret_change_in_production_with_strong_random_key
JWT_REFRESH_SECRET=nexora_dev_jwt_refresh_secret_change_in_production
JWT_EXPIRY_ACCESS=900
JWT_EXPIRY_REFRESH=604800
JWT_ISSUER=nexora.io
JWT_AUDIENCE=nexora-platform

# ============================================================================
# OAUTH & SSO
# ============================================================================
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback/microsoft

SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=
SAML_PRIVATE_KEY=

# ============================================================================
# AWS & CLOUD STORAGE
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=nexora-dev
S3_ENDPOINT=
CLOUDFRONT_DOMAIN=

# ============================================================================
# EMAIL & NOTIFICATIONS
# ============================================================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@nexora.io
SENDGRID_FROM_NAME=Nexora

# Development email (MailHog)
MAILHOG_HOST=localhost
MAILHOG_PORT=1025

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ============================================================================
# AI & LLM SERVICES
# ============================================================================
CLAUDE_API_KEY=
CLAUDE_API_ENDPOINT=https://api.anthropic.com
CLAUDE_MODEL=claude-3-sonnet

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

OPENAI_API_KEY=
OPENAI_API_ENDPOINT=https://api.openai.com/v1

# ============================================================================
# CORS & SECURITY
# ============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_PUSHGATEWAY=http://localhost:9091

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# Sentry (Error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=nexora

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Payroll
PAYROLL_TAX_SLAB=india  # india, us, uk

# Attendance
ATTENDANCE_GEOFENCE_ENABLED=true
ATTENDANCE_PHOTO_REQUIRED=false
ATTENDANCE_MANUAL_ENTRY_LIMIT=3

# Projects
PROJECT_DEFAULT_BOARD_TYPE=kanban  # kanban, scrum, custom

# Recruitment
RECRUITMENT_RESUME_OCR_ENABLED=true

# Backup
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# ============================================================================
# INTEGRATION WEBHOOKS
# ============================================================================
WEBHOOK_GITHUB_SECRET=
WEBHOOK_SLACK_SECRET=
WEBHOOK_STRIPE_SECRET=

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_AI_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_INTEGRATIONS_ENABLED=false
FEATURE_ANALYTICS_ENABLED=true
FEATURE_MOBILE_ENABLED=false

# ============================================================================
# DATADOG (Optional advanced monitoring)
# ============================================================================
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com
DATADOG_DISABLE_TELEMETRY=false
