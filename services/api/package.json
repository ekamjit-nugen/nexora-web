{
  "name": "@nexora/api",
  "version": "1.0.0",
  "description": "Nexora Modular Monolith — all 18 feature modules in one deployable. Each module is split-ready behind a public-API + event-bus boundary so it can be extracted back to its own service in <1 day without touching caller code.",
  "main": "dist/src/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main",
    "start:prod": "node dist/src/main",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:e2e": "jest --config jest.e2e.config.js",
    "module:bootstrap": "node dist/src/modules/${MODULE}/${MODULE}.bootstrap.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
