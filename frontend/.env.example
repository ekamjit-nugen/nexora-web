# =============================================================================
# Frontend env — copy to .env.local and tweak for your dev box.
# =============================================================================
# These NEXT_PUBLIC_* values are baked into the Next.js client bundle at
# build time. After changing them, you MUST rebuild:
#
#   docker compose -p nexora -f docker-compose.simple.yml build --no-cache frontend
#   docker compose -p nexora -f docker-compose.simple.yml up -d --force-recreate frontend
#
# To verify what's actually baked in:
#
#   docker exec nexora-frontend sh -c \
#     "find /app/.next -name '*.js' | xargs grep -hoE 'localhost:30[0-9]+' | sort -u"
#
# All three URLs point at the SAME monolith (port 3015). REST + chat WS +
# call WS all multiplex through it.
# =============================================================================

NEXT_PUBLIC_API_URL=http://localhost:3015
NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:3015
NEXT_PUBLIC_CALL_SOCKET_URL=http://localhost:3015

# When testing from a different machine on your LAN (e.g. mobile), replace
# `localhost` with your dev box's LAN IP (e.g. 192.168.1.42). The frontend
# container's CORS already permits the monolith.
