# =============================================================================
# Mobile env — copy to .env and tweak for your dev box.
# =============================================================================
# Expo bakes EXPO_PUBLIC_* values into the JS bundle when you run
# `expo start` or `expo build`. After changing them, you must restart
# Metro (Ctrl+C, then `npm start` again) — Metro caches aggressively.
#
# All API + WebSocket traffic multiplexes through the monolith on :3015.
# In the legacy 18-service stack chat was on :3002 and calling on :3051;
# those ports are gone post-cutover.
# =============================================================================

# REST + Socket.IO base URL.
#
# - Simulator / Emulator on the same machine:  http://localhost:3015
# - Real device on the LAN: http://<your-laptop's-LAN-IP>:3015
#   (find it via `ipconfig getifaddr en0` on macOS)
#
#   `localhost` from a phone points at the phone itself, not your laptop,
#   so you MUST use the LAN IP (e.g. 192.168.1.42) for real-device testing.
EXPO_PUBLIC_API_URL=http://localhost:3015

# Optional: only override if chat or calling has been split out into
# its own microservice (see docs/extract-to-microservice.md). In the
# monolith they live on the same port.
# EXPO_PUBLIC_CHAT_SOCKET_URL=http://localhost:3015
# EXPO_PUBLIC_CALL_SOCKET_URL=http://localhost:3015
